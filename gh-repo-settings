#!/usr/bin/env bash
# CLI entry point wrapping scripts/. Also installable as a gh extension
# (https://cli.github.com/manual/gh_extension) — gh requires the repository
# to be named gh-repo-settings for that.
#
# Usage:
#   gh-repo-settings sync [OWNER/REPO] [--dry-run] [--settings PATH]
#   gh-repo-settings check [OWNER/REPO] [--strict]
#
# sync   Apply .github/settings.yml to the repository's settings.
# check  Audit the repository against the secure-OSS baseline (read-only).
#
# The repository defaults to the origin remote of the current directory's
# checkout; the token comes from $GITHUB_TOKEN, $GH_TOKEN, or `gh auth token`.
set -euo pipefail

root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() { sed -n '2,14p' "$0" | sed 's/^# \{0,1\}//'; }

cmd="${1:-help}"
[[ $# -gt 0 ]] && shift

case "$cmd" in
  sync)
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --dry-run) export DRY_RUN=true ;;
        --settings)
          shift
          export SETTINGS_PATH="${1:?--settings needs a path}"
          ;;
        */*) export REPOSITORY="$1" ;;
        *)
          echo "Unknown argument: $1" >&2
          usage >&2
          exit 2
          ;;
      esac
      shift
    done
    exec "$root/scripts/sync-settings.sh"
    ;;
  check | healthcheck)
    exec "$root/scripts/healthcheck.sh" "$@"
    ;;
  help | -h | --help)
    usage
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    usage >&2
    exit 2
    ;;
esac
